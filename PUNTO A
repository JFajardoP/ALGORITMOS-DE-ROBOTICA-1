import math

# Asignación de coordenadas fijas
x, y, z = 4, 9, 10

# 1. Cálculos para Coordenadas Cilíndricas (r, theta, z)
r_cil = math.sqrt(x**2 + y**2)
theta = math.atan2(y, x)  # El resultado es en radianes

# 2. Cálculos para Coordenadas Esféricas (rho, theta, phi)
rho = math.sqrt(x**2 + y**2 + z**2)
# theta es el mismo que en cilíndricas
phi = math.acos(z / rho) if rho != 0 else 0

# Conversión selectiva a grados para visualización
theta_deg = math.degrees(theta)
phi_deg = math.degrees(phi)

# Salida de resultados
print(f"Coordenadas Rectangulares: ({x}, {y}, {z})")
print("-" * 30)
print(f"Cilíndricas: r = {r_cil:.4f}, θ = {theta_deg:.2f}°, z = {z}")
print(f"Esféricas:   ρ = {rho:.4f}, θ = {theta_deg:.2f}°, φ = {phi_deg:.2f}°")
print("-" * 30)

