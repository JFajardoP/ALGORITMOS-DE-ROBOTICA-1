import math

def rotacion_x(grados):
    # Convertimos la entrada a radianes internamente
    a = math.radians(grados)
    
    # Creamos la matriz usando las funciones de math
    matriz = [
        [1, 0, 0],
        [0, math.cos(a), -math.sin(a)],
        [0, math.sin(a), math.cos(a)]
    ]
    return matriz

def rotacion_y(grados):
    a = math.radians(grados)
    matriz = [
        [math.cos(a), 0, math.sin(a)],
        [0, 1, 0],
        [-math.sin(a), 0, math.cos(a)]
    ]
    return matriz

def rotacion_z(grados):
    a = math.radians(grados)
    matriz = [
        [math.cos(a), -math.sin(a), 0],
        [math.sin(a), math.cos(a), 0],
        [0, 0, 1]
    ]
    return matriz

# --- Ejemplo de uso con parámetros fijos ---
angulo_fijo = 90  # 90 grados

m_x = rotacion_x(angulo_fijo)

print(f"Matriz de rotación en X para {angulo_fijo}°:")
# Formateamos la impresión para que sea legible
for fila in m_x:
    print(f"[{fila[0]:.2f}, {fila[1]:.2f}, {fila[2]:.2f}]")
print("-" * 30)

