import math

def calcular_fuerzas_cilindro(presion_bar, diametro_embolo_mm, diametro_vasto_mm):
    # 1. Conversión de unidades a Sistema Internacional (SI)
    # Presión: 1 bar = 100,000 Pascales (N/m^2)
    presion_pa = presion_bar * 100000
    
    # Dimensiones: mm a metros
    d_embolo_m = diametro_embolo_mm / 1000
    d_vasto_m = diametro_vasto_mm / 1000
    
    # 2. Cálculo de Áreas (m^2)
    area_embolo = (math.pi * d_embolo_m**2) / 4
    area_vastago = (math.pi * d_vasto_m**2) / 4
    area_anular = area_embolo - area_vastago # Área efectiva para el retroceso
    
    # 3. Cálculo de Fuerzas (Newton)
    fuerza_avance = presion_pa * area_embolo
    fuerza_retroceso = presion_pa * area_anular
    
    return fuerza_avance, fuerza_retroceso

# --- Parámetros fijos ---
presion = 6.0          # bar
diametro_e = 50.0      # mm (50mm de émbolo)
diametro_v = 20.0      # mm (20mm de vástago)

f_av, f_re = calcular_fuerzas_cilindro(presion, diametro_e, diametro_v)

# Conversión a Kilogramos-fuerza para referencia común (1 kgf ≈ 9.81 N)
kgf_av = f_av / 9.81
kgf_re = f_re / 9.81

# Mostrar resultados
print(f"--- Datos del Cilindro ---")
print(f"Presión: {presion} bar | Émbolo: {diametro_e}mm | Vástago: {diametro_v}mm")
print("-" * 35)
print(f"Fuerza de Avance:   {f_av:.2f} N ({kgf_av:.2f} kgf)")
print(f"Fuerza de Retroceso: {f_re:.2f} N ({kgf_re:.2f} kgf)")

print("-" * 30)
