def calcular_resistencia_pt100(t):
    # Constantes de Callendar-Van Dusen (DIN/IEC 60751)
    R0 = 100.0
    A = 3.9083e-3
    B = -5.775e-7
    C = -4.183e-12

    if t >= 0:
        # Fórmula para temperaturas positivas
        rt = R0 * (1 + A * t + B * t**2)
    else:
        # Fórmula para temperaturas negativas
        rt = R0 * (1 + A * t + B * t**2 + C * (t - 100) * t**3)
    
    return rt

# --- Configuración de valores fijos ---
temperatura = 120.0  # Grados Celsius
resistencia_resultante = calcular_resistencia_pt100(temperatura)

# Salida de resultados
print(f"--- Cálculo de Resistencia RTD PT100 ---")
print(f"Temperatura: {temperatura} °C")
print(f"Resistencia calculada:    {resistencia_resultante:.4f} Ω")
print("-" * 30)

